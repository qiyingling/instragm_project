      <aliases enabled='yes' />
      <column caption='social-level' datatype='string' name='[Calculation_15277721557348353]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [following_n (user_segment)] &gt; 10 then &quot;high social&quot;&#13;&#10;elseif [following_n (user_segment)] &gt; 5 then &quot;medium social&quot;&#13;&#10;ELSE &quot;low social&quot;&#13;&#10;END' />
      </column>
